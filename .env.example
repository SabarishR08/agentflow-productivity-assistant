# Set ENV=prod to force PostgreSQL/AlloyDB connection usage.
ENV=dev

# PostgreSQL or AlloyDB SQLAlchemy URL example:
# postgresql+psycopg://postgres:password@127.0.0.1:5432/agentflow
DATABASE_URL=sqlite:///./agentflow.db

# Gemini planner
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# MCP connectors (Zapier MCP / calendar MCP gateway endpoints)
MCP_TODOIST_URL=
MCP_TODOIST_TOKEN=
MCP_CALENDAR_URL=
MCP_CALENDAR_TOKEN=

# Gemini settings (set at least one credential option)
GEMINI_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=

# API service settings
PORT=8080
